# ── LLM API Keys ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Paths ─────────────────────────────────────────────────────────────────────
# Absolute path to the local repository to analyze
REPO_PATH=/path/to/your-repo

# Where generated content bundles are written
OUTPUT_PATH=./output/teaching_guides

# ── Model Selection ───────────────────────────────────────────────────────────
# claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5-20251001
DEFAULT_WRITER_MODEL=claude-sonnet-4-6
DEFAULT_RESEARCH_MODEL=claude-sonnet-4-6

# gpt-4o | gpt-4o-mini
DEFAULT_OPENAI_MODEL=gpt-4o

# ── Pipeline Settings ─────────────────────────────────────────────────────────
# Number of concepts to process in parallel during --batch mode
BATCH_SIZE=3

# Maximum writer → reviewer → editor revision loops per concept
MAX_REVISIONS=2

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
